# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.

# --- Supabase ---
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# Server-side only — bypasses RLS, never expose to client
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# --- MapTiler ---
# Free tier at https://cloud.maptiler.com/
# Domain-restrict this key in the MapTiler dashboard to your Vercel URL
NEXT_PUBLIC_MAPTILER_KEY=YOUR_MAPTILER_KEY_HERE
